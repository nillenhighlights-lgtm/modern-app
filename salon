<!doctype html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, viewport-fit=cover" />
  <meta name="theme-color" content="#f28c28" />
  <title>Модерн — мобильное приложение</title>
  <style>
    :root{
      --bg:#f4f7fb;
      --card:#ffffff;
      --text:#102033;
      --muted:#6f7e8f;
      --line:#e7edf5;
      --orange:#f28c28;
      --orange2:#ffb45c;
      --blue:#2d6cdf;
      --blue2:#4f88ff;
      --green:#2da56a;
      --red:#e85d5d;
      --shadow:0 16px 44px rgba(16,32,51,.10);
      --radius:22px;
      --safe-top:env(safe-area-inset-top);
      --safe-bottom:env(safe-area-inset-bottom);
    }
    *{box-sizing:border-box}
    html,body{height:100%;margin:0}
    body{
      font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Inter,Arial,sans-serif;
      background:
        radial-gradient(circle at top left, rgba(242,140,40,.14), transparent 26%),
        radial-gradient(circle at top right, rgba(45,108,223,.12), transparent 28%),
        var(--bg);
      color:var(--text);
      overscroll-behavior:none;
      -webkit-tap-highlight-color: transparent;
    }
    a{color:inherit;text-decoration:none}
    button,input,select,textarea{font:inherit}
    .app{
      min-height:100vh;
      display:flex;
      justify-content:center;
      padding:0;
    }
    .shell{
      width:100%;
      max-width:430px;
      min-height:100vh;
      background:linear-gradient(180deg,#fcfdff 0%, #f4f7fb 100%);
      position:relative;
      overflow:hidden;
      box-shadow:none;
    }
    .top-safe{height:var(--safe-top);background:#fff}
    .statusbar{
      padding:10px 16px 8px;
      display:flex;
      justify-content:space-between;
      align-items:center;
      font-size:12px;
      color:#6d7b8a;
      background:rgba(255,255,255,.92);
      backdrop-filter:blur(12px);
      border-bottom:1px solid rgba(231,237,245,.8);
      position:sticky;
      top:0;
      z-index:10;
    }
    .brandbar{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:12px;
      padding:12px 16px;
      background:rgba(255,255,255,.88);
      border-bottom:1px solid var(--line);
      position:sticky;
      top:42px;
      z-index:9;
      backdrop-filter:blur(12px);
    }
    .brand{display:flex;align-items:center;gap:10px;min-width:0}
    .logo{
      width:42px;height:42px;border-radius:15px;
      background:linear-gradient(135deg,var(--orange),var(--blue));
      color:#fff;font-weight:900;display:grid;place-items:center;
      box-shadow:0 10px 22px rgba(45,108,223,.18);
      flex:none;
    }
    .brand h1{font-size:16px;line-height:1.1;margin:0}
    .brand p{margin:3px 0 0;font-size:11px;color:var(--muted)}
    .avatar{
      width:40px;height:40px;border-radius:50%;overflow:hidden;
      border:1px solid var(--line);flex:none;
      background:linear-gradient(135deg,#ecf2ff,#fff);
    }
    .avatar svg{width:100%;height:100%}
    .content{
      height:calc(100vh - 42px - 66px - var(--safe-top) - var(--safe-bottom) - 72px);
      overflow:auto;
      padding:16px 16px 24px;
      -webkit-overflow-scrolling:touch;
    }
    .screen{display:none;animation:fade .2s ease}
    .screen.active{display:block}
    @keyframes fade{from{opacity:.3;transform:translateY(4px)}to{opacity:1;transform:none}}
    .hero{
      border-radius:28px;
      padding:18px;
      background:linear-gradient(135deg, rgba(242,140,40,.96), rgba(45,108,223,.92));
      color:#fff;
      box-shadow:var(--shadow);
      overflow:hidden;
      position:relative;
    }
    .hero:after{
      content:"";
      position:absolute;inset:auto -20px -24px auto;
      width:120px;height:120px;border-radius:50%;
      background:rgba(255,255,255,.12);
      filter:blur(4px);
    }
    .hero h2{margin:0 0 8px;font-size:22px;line-height:1.05}
    .hero p{margin:0 0 14px;font-size:13px;opacity:.94;max-width:28ch}
    .pill-row{display:flex;gap:8px;flex-wrap:wrap}
    .pill{padding:8px 10px;border-radius:999px;background:rgba(255,255,255,.16);border:1px solid rgba(255,255,255,.25);font-size:12px}
    .grid2{display:grid;grid-template-columns:1fr 1fr;gap:12px}
    .card{
      background:var(--card);
      border:1px solid var(--line);
      border-radius:var(--radius);
      box-shadow:0 8px 24px rgba(16,32,51,.05);
      padding:14px;
    }
    .card h3,.section-title{margin:0 0 10px;font-size:15px}
    .muted{color:var(--muted)}
    .small{font-size:12px;line-height:1.4}
    .row{display:flex;gap:10px;align-items:center}
    .space{justify-content:space-between}
    .stack{display:flex;flex-direction:column;gap:10px}
    .btn{
      border:none;border-radius:16px;padding:13px 14px;font-weight:700;cursor:pointer;
      transition:.15s transform,.15s opacity,.15s background;
      touch-action:manipulation;
    }
    .btn:active{transform:scale(.98)}
    .btn-primary{background:linear-gradient(135deg,var(--orange),var(--blue));color:#fff;box-shadow:0 10px 22px rgba(242,140,40,.18)}
    .btn-soft{background:#eef4ff;color:#2453b8}
    .btn-ghost{background:#f6f8fc;color:#425062}
    .btn-danger{background:#fff0f0;color:#c43f3f}
    .btn-green{background:#eefaf3;color:#1d7b4c}
    .btn-block{width:100%}
    .chip{
      display:inline-flex;align-items:center;gap:6px;
      padding:9px 11px;border-radius:999px;border:1px solid var(--line);
      background:#fff;font-size:12px;color:#3d4d60;font-weight:600;
    }
    .chip.active{border-color:rgba(45,108,223,.25);background:#eef4ff;color:#2453b8}
    .chips{display:flex;gap:8px;flex-wrap:wrap}
    .service-tile,.master-tile,.family-tile,.product-tile,.history-tile{
      border:1px solid var(--line);
      border-radius:20px;
      background:#fff;
      padding:14px;
      box-shadow:0 8px 20px rgba(16,32,51,.04);
    }
    .thumb{
      width:56px;height:56px;border-radius:18px;flex:none;
      background:linear-gradient(135deg,#fbe1c2,#dce9ff);
      display:grid;place-items:center;font-size:24px;
    }
    .thumb.small{width:44px;height:44px;border-radius:14px;font-size:18px}
    .title{margin:0;font-size:14px}
    .meta{margin:4px 0 0;font-size:12px;color:var(--muted)}
    .price{font-weight:800;font-size:14px}
    .list{display:flex;flex-direction:column;gap:10px}
    .service-tile,.master-tile,.history-tile,.product-tile{display:flex;gap:12px;align-items:flex-start}
    .family-tile{display:flex;justify-content:space-between;align-items:center;gap:10px}
    .avatar-mini{
      width:44px;height:44px;border-radius:50%;display:grid;place-items:center;
      background:linear-gradient(135deg,#fff,#edf4ff);border:1px solid var(--line);font-weight:800;color:#27496d;flex:none;
    }
    .input, .select, .textarea{
      width:100%;border:1px solid var(--line);border-radius:16px;background:#fff;
      padding:13px 14px;outline:none;color:var(--text);
      transition:.15s border-color,.15s box-shadow;
    }
    .input:focus,.select:focus,.textarea:focus{border-color:rgba(45,108,223,.35);box-shadow:0 0 0 4px rgba(45,108,223,.08)}
    .textarea{min-height:88px;resize:none}
    .field{display:flex;flex-direction:column;gap:7px}
    .label{font-size:12px;color:var(--muted);font-weight:700}
    .top-title{display:flex;align-items:flex-start;justify-content:space-between;gap:10px;margin-bottom:12px}
    .top-title h2{margin:0;font-size:19px;line-height:1.1}
    .top-title p{margin:5px 0 0;color:var(--muted);font-size:12px}
    .stepper{display:flex;gap:8px;flex-wrap:wrap;margin:6px 0 12px}
    .step{padding:8px 10px;border-radius:999px;background:#f5f8fd;color:#6d7b8a;font-size:12px;font-weight:700}
    .step.active{background:linear-gradient(135deg,var(--orange),var(--blue));color:#fff}
    .bottom-nav{
      position:sticky;
      bottom:0;
      padding-bottom:calc(10px + var(--safe-bottom));
      background:rgba(255,255,255,.96);
      border-top:1px solid var(--line);
      display:grid;
      grid-template-columns:repeat(4,1fr);
      gap:4px;
    }
    .nav-item{
      display:flex;flex-direction:column;align-items:center;justify-content:center;gap:3px;
      padding:10px 4px 8px;font-size:11px;color:#6d7b8a;font-weight:700;
    }
    .nav-item .ico{font-size:18px;line-height:1}
    .nav-item.active{color:#2453b8}
    .nav-item.active .ico{filter:saturate(1.2)}
    .badge{
      display:inline-flex;align-items:center;justify-content:center;
      min-width:20px;height:20px;padding:0 6px;border-radius:999px;
      background:var(--orange);color:#fff;font-size:11px;font-weight:800;
    }
    .toast{
      position:fixed;left:50%;transform:translateX(-50%);
      bottom:calc(90px + var(--safe-bottom));
      background:rgba(16,32,51,.92);color:#fff;padding:12px 14px;border-radius:14px;
      font-size:13px;box-shadow:0 12px 30px rgba(0,0,0,.22);opacity:0;pointer-events:none;transition:.25s;
      max-width:min(92vw,420px);z-index:99;
    }
    .toast.show{opacity:1}
    .modal{
      position:fixed;inset:0;background:rgba(13,20,32,.45);
      display:none;align-items:flex-end;justify-content:center;padding:12px;z-index:100;
    }
    .modal.show{display:flex}
    .sheet{
      width:100%;max-width:430px;background:#fff;border-radius:24px 24px 18px 18px;
      padding:16px;box-shadow:0 -20px 50px rgba(0,0,0,.18);
      padding-bottom:calc(16px + var(--safe-bottom));
    }
    .sheet h3{margin:0 0 10px;font-size:17px}
    .divider{height:1px;background:var(--line);margin:12px 0}
    .gallery{display:grid;grid-template-columns:1fr 1fr;gap:10px}
    .beforeafter{border-radius:18px;overflow:hidden;border:1px solid var(--line);background:#fff}
    .ba-top{height:86px;display:grid;place-items:center;font-weight:800;color:#fff}
    .ba-bottom{padding:10px;font-size:12px;color:var(--muted)}
    .tag{display:inline-block;padding:6px 9px;border-radius:999px;background:#f3f7ff;color:#2453b8;font-size:11px;font-weight:700}
    .checklist{display:flex;flex-direction:column;gap:9px}
    .check{display:flex;align-items:flex-start;gap:10px}
    .check .box{width:18px;height:18px;border-radius:6px;background:#eef4ff;color:#2453b8;display:grid;place-items:center;font-size:12px;flex:none;margin-top:1px}
    .hero-actions{display:flex;gap:10px;flex-wrap:wrap;margin-top:12px}
    .hidden{display:none !important}
    .phone-frame-note{display:none}
    .safe-bottom-gap{height:10px}
    @media (min-width: 700px){
      .app{padding:12px}
      .shell{min-height:calc(100vh - 24px);border-radius:28px;overflow:hidden;max-width:430px;box-shadow:0 25px 70px rgba(0,0,0,.14)}
      .phone-frame-note{display:block;text-align:center;font-size:12px;color:#718197;margin:8px 0 0}
    }
    @media (prefers-reduced-motion: reduce){
      *,*::before,*::after{animation:none !important;transition:none !important;scroll-behavior:auto !important}
    }
  </style>
</head>
<body>
  <div class="app">
    <div class="shell">
      <div class="top-safe"></div>
      <div class="statusbar">
        <div id="statusTime">09:41</div>
        <div>▮▮▮&nbsp;&nbsp;5G&nbsp;&nbsp;100%</div>
      </div>
      <div class="brandbar">
        <div class="brand">
          <div class="logo">М</div>
          <div>
            <h1>Модерн</h1>
            <p id="headerSubtitle">семейный салон красоты</p>
          </div>
        </div>
        <div class="avatar" title="Профиль">
          <svg viewBox="0 0 100 100" aria-hidden="true">
            <rect width="100" height="100" rx="50" fill="url(#g)"/>
            <defs>
              <linearGradient id="g" x1="0" x2="1" y1="0" y2="1">
                <stop offset="0" stop-color="#eef4ff"/>
                <stop offset="1" stop-color="#ffffff"/>
              </linearGradient>
            </defs>
            <circle cx="50" cy="38" r="18" fill="#9fb5d4"/>
            <path d="M22 84c4-17 18-24 28-24s24 7 28 24" fill="#9fb5d4"/>
          </svg>
        </div>
      </div>

      <main class="content">
        <!-- LOGIN -->
        <section class="screen active" id="screen-login">
          <div class="hero">
            <h2>Вход в приложение салона</h2>
            <p>Онлайн-запись, семейные профили, чат с мастером и бонусы — всё в одном месте.</p>
            <div class="pill-row">
              <div class="pill">быстрый вход</div>
              <div class="pill">под iPhone</div>
              <div class="pill">рабочий ввод</div>
            </div>
          </div>

          <div class="card" style="margin-top:12px">
            <h3>Войти по номеру телефона</h3>
            <div class="stack">
              <div class="field">
                <div class="label">Номер телефона</div>
                <input id="phoneInput" class="input" inputmode="tel" placeholder="+7 (___) ___-__-__" value="+7 (999) 123-45-67" />
              </div>
              <div class="field hidden" id="codeBlock">
                <div class="label">Код из SMS</div>
                <input id="codeInput" class="input" inputmode="numeric" maxlength="4" placeholder="1234" />
              </div>
              <button class="btn btn-primary btn-block" id="sendCodeBtn">Получить код</button>
              <button class="btn btn-green btn-block hidden" id="loginBtn">Войти</button>
            </div>
            <div class="small muted" style="margin-top:10px">Демо-версия: код можно ввести любой, чтобы перейти дальше.</div>
          </div>

          <div class="grid2" style="margin-top:12px">
            <div class="card">
              <div class="section-title">Фишка</div>
              <div class="small muted">Семейная запись: выбираете не только себя, но и любого члена семьи с одного профиля.</div>
            </div>
            <div class="card">
              <div class="section-title">Бонусы</div>
              <div class="small muted">Баллы копятся за визиты и потом списываются на услугу или товар.</div>
            </div>
          </div>
        </section>

        <!-- HOME -->
        <section class="screen" id="screen-home">
          <div class="hero">
            <h2 id="homeGreeting">Привет, Анна</h2>
            <p>Сегодня у вас есть запись и 320 бонусов на балансе.</p>
            <div class="pill-row">
              <div class="pill">320 баллов</div>
              <div class="pill">1 активная запись</div>
              <div class="pill">семья 4 человека</div>
            </div>
            <div class="hero-actions">
              <button class="btn btn-block btn-primary" id="quickBookBtn" style="flex:1">Записаться</button>
              <button class="btn btn-block btn-ghost" id="openChatShortcut" style="flex:1">Чат с мастером</button>
            </div>
          </div>

          <div class="grid2" style="margin-top:12px">
            <div class="card">
              <div class="section-title">Бонусы</div>
              <div style="font-size:26px;font-weight:900">320</div>
              <div class="small muted">Можно списать до 20% от услуги.</div>
            </div>
            <div class="card">
              <div class="section-title">Следующий визит</div>
              <div style="font-weight:800">12 апреля, 15:20</div>
              <div class="small muted">Женская стрижка • Марина</div>
            </div>
          </div>

          <div class="card" style="margin-top:12px">
            <div class="row space">
              <h3>Семейные профили</h3>
              <button class="btn btn-soft" id="goFamilyBtn" style="padding:10px 12px">Открыть</button>
            </div>
            <div class="chips" id="familyChips"></div>
          </div>

          <div class="card" style="margin-top:12px">
            <div class="row space">
              <h3>Популярные услуги</h3>
              <span class="tag">2 демо-услуги</span>
            </div>
            <div class="list" style="margin-top:10px">
              <div class="service-tile">
                <div class="thumb">✂️</div>
                <div style="flex:1">
                  <p class="title">Женская стрижка</p>
                  <p class="meta">60 минут • мастер Марина • от 1 800 ₽</p>
                </div>
                <button class="btn btn-soft" data-go="service">Подробнее</button>
              </div>
              <div class="service-tile">
                <div class="thumb">🎨</div>
                <div style="flex:1">
                  <p class="title">Окрашивание</p>
                  <p class="meta">120 минут • консультация + уход</p>
                </div>
                <button class="btn btn-ghost" data-go="booking">Запись</button>
              </div>
            </div>
          </div>

          <div class="card" style="margin-top:12px">
            <div class="row space">
              <h3>Мастер рекомендует</h3>
              <button class="btn btn-soft" id="openCatalogBtn" style="padding:10px 12px">Каталог</button>
            </div>
            <div class="small muted">После стрижки мастер советует уход: шампунь, маску, спрей — можно забронировать и забрать в салоне.</div>
          </div>
        </section>

        <!-- BOOKING -->
        <section class="screen" id="screen-booking">
          <div class="top-title">
            <div>
              <h2>Онлайн-запись</h2>
              <p>Путь клиента: кто, что, у кого и когда.</p>
            </div>
            <span class="tag">работает</span>
          </div>
          <div class="stepper">
            <div class="step active">1. Кого</div>
            <div class="step" id="stepService">2. Услуга</div>
            <div class="step" id="stepMaster">3. Мастер</div>
            <div class="step" id="stepTime">4. Время</div>
          </div>

          <div class="card">
            <div class="field">
              <div class="label">Записать</div>
              <div class="chips" id="bookForChips"></div>
            </div>
            <div class="divider"></div>
            <div class="field">
              <div class="label">Услуга</div>
              <div class="chips" id="serviceChips"></div>
            </div>
            <div class="divider"></div>
            <div class="field">
              <div class="label">Мастер</div>
              <div class="chips" id="masterChips"></div>
            </div>
            <div class="divider"></div>
            <div class="grid2">
              <div class="field">
                <div class="label">Дата</div>
                <input class="input" id="dateInput" type="date" />
              </div>
              <div class="field">
                <div class="label">Время</div>
                <select class="select" id="timeInput"></select>
              </div>
            </div>
            <div class="divider"></div>
            <div class="field">
              <div class="label">Комментарий</div>
              <textarea class="textarea" id="commentInput" placeholder="Например: хочу аккуратно сохранить длину и сделать мягкую чёлку."></textarea>
            </div>
            <div class="divider"></div>
            <div class="checklist">
              <div class="check"><div class="box">✓</div><div class="small">Оплата в приложении: демонстрационная кнопка оплаты.</div></div>
              <div class="check"><div class="box">✓</div><div class="small">Баллы можно списать сразу при оформлении записи.</div></div>
            </div>
            <div class="hero-actions" style="margin-top:14px">
              <button class="btn btn-primary" id="confirmBookingBtn" style="flex:1">Подтвердить запись</button>
              <button class="btn btn-ghost" id="openCancelModalBtn" style="flex:1">Отменить / перенести</button>
            </div>
          </div>
        </section>

        <!-- SERVICE -->
        <section class="screen" id="screen-service">
          <div class="top-title">
            <div>
              <h2>Женская стрижка</h2>
              <p>Услуга с понятным сценарием и переходом дальше.</p>
            </div>
            <span class="tag">демо</span>
          </div>
          <div class="card">
            <div class="row space">
              <div>
                <div style="font-size:30px;font-weight:900">1 800 ₽</div>
                <div class="small muted">60 минут • включает консультацию</div>
              </div>
              <div class="thumb small">✂️</div>
            </div>
            <div class="divider"></div>
            <div class="small muted">В карточке можно показать описание, стоимость, что входит и рекомендации мастера.</div>
            <div class="hero-actions">
              <button class="btn btn-primary" data-go="booking" style="flex:1">Записаться</button>
              <button class="btn btn-soft" data-go="master" style="flex:1">К мастеру</button>
            </div>
          </div>
          <div class="card" style="margin-top:12px">
            <h3>Что происходит после услуги</h3>
            <div class="small muted">История посещения, фото до/после и рекомендации по уходу.</div>
          </div>
        </section>

        <!-- MASTER -->
        <section class="screen" id="screen-master">
          <div class="top-title">
            <div>
              <h2>Мастер Марина</h2>
              <p>Профиль специалиста, сертификаты, работы и чат.</p>
            </div>
            <span class="tag">4.9 ★</span>
          </div>
          <div class="card">
            <div class="master-tile" style="padding:0;border:none;box-shadow:none">
              <div class="thumb" style="width:66px;height:66px;border-radius:22px">👩‍🦰</div>
              <div style="flex:1">
                <p class="title">Марина Алексеевна</p>
