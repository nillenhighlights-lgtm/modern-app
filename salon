  <script>
    const STORAGE_KEY = 'modern-salon-app-v1';
    const state = {
      user: { name: 'Анна', phone: '+7 (999) 123-45-67' },
      family: [
        { name: 'Анна', role: 'мама' },
        { name: 'Игорь', role: 'муж' },
        { name: 'Лиза', role: 'дочка' },
        { name: 'Миша', role: 'сын' }
      ],
      selectedFamily: 'Анна',
      selectedService: 'Женская стрижка',
      selectedMaster: 'Марина',
      selectedDate: '',
      selectedTime: '15:20',
      bonus: 320,
      reserved: [],
      chat: [
        { who: 'master', text: 'Здравствуйте! Подскажите, что вы хотите изменить в стрижке?' },
        { who: 'client', text: 'Хочу сохранить длину и добавить объём у лица.' }
      ],
      bookingActive: true
    };

    const services = [
      { name: 'Женская стрижка', price: '1 800 ₽', emoji: '✂️' },
      { name: 'Окрашивание', price: 'от 3 500 ₽', emoji: '🎨' }
    ];
    const masters = [
      { name: 'Марина', emoji: '👩‍🦰', descr: '12 лет опыта' },
      { name: 'Ольга', emoji: '💇‍♀️', descr: 'детские стрижки' }
    ];
    const times = ['09:00','10:00','11:30','13:00','15:20','17:00','18:30'];

    const $ = (s) => document.querySelector(s);
    const $$ = (s) => Array.from(document.querySelectorAll(s));

    function save(){ localStorage.setItem(STORAGE_KEY, JSON.stringify(state)); }
    function load(){
      try {
        const saved = JSON.parse(localStorage.getItem(STORAGE_KEY) || 'null');
        if(saved && typeof saved === 'object') Object.assign(state, saved);
      } catch(e) {}
    }
    function toast(msg){
      const el = $('#toast');
      el.textContent = msg;
      el.classList.add('show');
      clearTimeout(toast._t);
      toast._t = setTimeout(() => el.classList.remove('show'), 2200);
    }
    function openModal(id){ $(id).classList.add('show'); }
    function closeModal(id){ $(id).classList.remove('show'); }

    function route(name){
      location.hash = '#' + name;
      render();
    }
    function getRoute(){
      return (location.hash || '#login').replace('#','');
    }

    function renderBottom(routeName){
      $$('#bottomNav .nav-item').forEach(i => i.classList.remove('active'));
      const map = {home:0, booking:1, master:2, chat:2, history:0, catalog:0, family:0, profile:3, service:0};
      const idx = map[routeName];
      if(typeof idx === 'number' && $$('#bottomNav .nav-item')[idx]) $$('#bottomNav .nav-item')[idx].classList.add('active');
    }

    function setActiveScreen(name){
      $$('.screen').forEach(s => s.classList.toggle('active', s.id === 'screen-' + name));
      renderBottom(name);
      $('#headerSubtitle').textContent = name === 'login' ? 'семейный салон красоты' : 'онлайн-запись и личный кабинет';
      $('#contentScrollToTop');
      const c = document.querySelector('.content');
      if(c) c.scrollTop = 0;
    }

    function renderChips(){
      const familyChips = $('#familyChips');
      familyChips.innerHTML = state.family.map(p => `
        <button class="chip ${state.selectedFamily===p.name ? 'active':''}" data-family="${p.name}">${p.name} • ${p.role}</button>
      `).join('');
      familyChips.querySelectorAll('button').forEach(btn => btn.addEventListener('click', () => {
        state.selectedFamily = btn.dataset.family;
        save(); render(); toast('Выбрано: ' + state.selectedFamily);
      }));

      const bookFor = $('#bookForChips');
      bookFor.innerHTML = state.family.map(p => `
        <button class="chip ${state.selectedFamily===p.name ? 'active':''}" data-family="${p.name}">${p.name}</button>
      `).join('') + '<button class="chip">+ Член семьи</button>';
      bookFor.querySelectorAll('button[data-family]').forEach(btn => btn.addEventListener('click', () => {
        state.selectedFamily = btn.dataset.family;
        save(); render();
      }));

      const serviceChips = $('#serviceChips');
      serviceChips.innerHTML = services.map(s => `
        <button class="chip ${state.selectedService===s.name ? 'active':''}" data-service="${s.name}">${s.emoji} ${s.name}</button>
      `).join('');
      serviceChips.querySelectorAll('button').forEach(btn => btn.addEventListener('click', () => {
        state.selectedService = btn.dataset.service;
        save(); render();
      }));

      const masterChips = $('#masterChips');
      masterChips.innerHTML = masters.map(m => `
        <button class="chip ${state.selectedMaster===m.name ? 'active':''}" data-master="${m.name}">${m.emoji} ${m.name}</button>
      `).join('');
      masterChips.querySelectorAll('button').forEach(btn => btn.addEventListener('click', () => {
        state.selectedMaster = btn.dataset.master;
        save(); render();
      }));
    }

    function renderFamily(){
      const list = $('#familyList');
      list.innerHTML = state.family.map((p, i) => `
        <div class="family-tile">
          <div class="row" style="gap:12px">
            <div class="avatar-mini">${p.name.slice(0,1).toUpperCase()}</div>
            <div>
              <div style="font-weight:800">${p.name}</div>
              <div class="small muted">${p.role}</div>
            </div>
          </div>
          <button class="btn btn-ghost" data-select-family="${p.name}">Выбрать</button>
        </div>
      `).join('');
      list.querySelectorAll('[data-select-family]').forEach(btn => btn.addEventListener('click', () => {
        state.selectedFamily = btn.dataset.selectFamily;
        save();
        toast('Профиль выбран: ' + state.selectedFamily);
        route('booking');
      }));
    }

    function renderBooking(){
      const dateInput = $('#dateInput');
      if(!dateInput.value){
        const d = new Date(); d.setDate(d.getDate()+2);
        dateInput.value = d.toISOString().slice(0,10);
      }
      state.selectedDate = dateInput.value;
      const timeSel = $('#timeInput');
      timeSel.innerHTML = times.map(t => `<option ${state.selectedTime===t?'selected':''}>${t}</option>`).join('');
      timeSel.value = state.selectedTime;
    }

    function renderChat(){
      const box = $('#chatBox');
      box.innerHTML = state.chat.map(m => `
        <div class="${m.who==='client' ? 'row' : 'row'}" style="justify-content:${m.who==='client' ? 'flex-end' : 'flex-start'}">
          <div style="max-width:84%;padding:12px 14px;border-radius:18px;background:${m.who==='client' ? 'linear-gradient(135deg,#2d6cdf,#4f88ff)' : '#f4f7fb'};color:${m.who==='client' ? '#fff' : 'var(--text)'};border:1px solid ${m.who==='client' ? 'transparent' : 'var(--line)'};font-size:13px;line-height:1.45">${m.text}</div>
        </div>
      `).join('');
      box.scrollTop = box.scrollHeight;
    }

    function renderReserved(){
      const el = $('#reservedList');
      if(!state.reserved.length){ el.textContent = 'Пока ничего не забронировано.'; return; }
      el.innerHTML = state.reserved.map(x => `<div style="padding:8px 0;border-bottom:1px solid var(--line)">${x}</div>`).join('');
    }

    function renderTime(){
      const d = new Date();
      $('#statusTime').textContent = d.toLocaleTimeString('ru-RU', {hour:'2-digit', minute:'2-digit'});
    }

    function render(){
      load();
      let current = getRoute();
      if(!current || !$('#screen-' + current)) {
        current = 'login';
        if(location.hash !== '#login') location.hash = '#login';
      }
      setActiveScreen(current);
      renderBottom(current);
      renderChips();
      renderFamily();
      renderBooking();
      renderChat();
      renderReserved();
      $('#homeGreeting').textContent = `Привет, ${state.user.name}`;
      $('#headerSubtitle').textContent = current === 'login' ? 'семейный салон красоты' : 'онлайн-запись и личный кабинет';
      $$('.btn[data-go], .nav-item[data-go]').forEach(btn => {
        btn.onclick = () => route(btn.dataset.go);
      });
      $('.badge').textContent = state.bonus;
      $$('#familyChips .chip').forEach(ch => ch.classList.toggle('active', ch.dataset.family === state.selectedFamily));
      $$('#bookForChips .chip').forEach(ch => ch.classList.toggle('active', ch.dataset.family === state.selectedFamily));
      $$('#serviceChips .chip').forEach(ch => ch.classList.toggle('active', ch.dataset.service === state.selectedService));
      $$('#masterChips .chip').forEach(ch => ch.classList.toggle('active', ch.dataset.master === state.selectedMaster));
    }

    $('#sendCodeBtn').addEventListener('click', () => {
      $('#codeBlock').classList.remove('hidden');
      $('#loginBtn').classList.remove('hidden');
      $('#sendCodeBtn').classList.add('hidden');
      toast('Код отправлен в SMS');
    });

    $('#loginBtn').addEventListener('click', () => {
      state.user.phone = $('#phoneInput').value.trim() || state.user.phone;
      state.user.name = 'Анна';
      save();
      toast('Вход выполнен');
      route('home');
    });

    $('#quickBookBtn').addEventListener('click', () => route('booking'));
    $('#openChatShortcut').addEventListener('click', () => route('chat'));
    $('#goFamilyBtn').addEventListener('click', () => route('family'));
    $('#openCatalogBtn').addEventListener('click', () => route('catalog'));
    $('#openChatBtn').addEventListener('click', () => route('chat'));
    $('#openBeforeAfterBtn').addEventListener('click', () => openModal('#afterModal'));
    $('#closeAfterBtn').addEventListener('click', () => closeModal('#afterModal'));
    $('#openCancelModalBtn').addEventListener('click', () => openModal('#cancelModal'));
    $('#closeModalBtn').addEventListener('click', () => closeModal('#cancelModal'));
    $('#cancelBookingBtn').addEventListener('click', () => {
      state.bookingActive = false;
      save();
      closeModal('#cancelModal');
      toast('Запись отменена');
    });
    $('#rescheduleBtn').addEventListener('click', () => {
      closeModal('#cancelModal');
      route('booking');
      toast('Выберите новое время');
    });
    $('#confirmBookingBtn').addEventListener('click', () => {
      state.selectedDate = $('#dateInput').value;
      state.selectedTime = $('#timeInput').value;
      const summary = `${state.selectedService} для ${state.selectedFamily} • ${state.selectedDate} ${state.selectedTime} • мастер ${state.selectedMaster}`;
      state.bookingActive = true;
      state.reserved.unshift(summary);
      state.chat.push({ who:'master', text:'Запись подтверждена. Ждём вас в салоне.' });
      save();
      render();
      route('home');
      toast('Запись подтверждена');
    });

    $('#sendChatBtn').addEventListener('click', () => {
      const inp = $('#chatInput');
      const text = inp.value.trim();
      if(!text) return;
      state.chat.push({ who:'client', text });
      inp.value = '';
      save();
      renderChat();
      setTimeout(() => {
        state.chat.push({ who:'master', text:'Спасибо! Я подскажу по процедуре и подберу подходящий уход.' });
        save();
        renderChat();
      }, 700);
    });

    $('#addFamilyBtn').addEventListener('click', () => {
      const name = $('#familyName').value.trim();
      const role = $('#familyRole').value.trim();
      if(!name || !role){ toast('Заполните имя и роль'); return; }
      state.family.push({ name, role });
      $('#familyName').value = '';
      $('#familyRole').value = '';
      save(); render(); toast('Профиль добавлен');
    });

    $('#payBtn').addEventListener('click', () => openModal('#payModal'));
    $('#closePayBtn').addEventListener('click', () => closeModal('#payModal'));
    $('#finishPayBtn').addEventListener('click', () => {
      state.bonus = Math.max(0, state.bonus - 200);
      save(); render(); closeModal('#payModal'); toast('Оплата проведена');
    });
    $('#notifyBtn').addEventListener('click', () => toast('Уведомления включены'));

    $$('.reserve-btn').forEach(btn => btn.addEventListener('click', () => {
      state.reserved.push(`${btn.dataset.product} • забронировано для самовывоза`);
      save(); renderReserved(); toast('Товар забронирован');
      route('catalog');
    }));

    $$('#bottomNav .nav-item').forEach(item => item.addEventListener('click', () => route(item.dataset.go)));
    $$('.modal').forEach(mod => mod.addEventListener('click', (e) => { if(e.target === mod) mod.classList.remove('show'); }));
    $('#dateInput').addEventListener('change', () => { state.selectedDate = $('#dateInput').value; save(); });
    $('#timeInput').addEventListener('change', () => { state.selectedTime = $('#timeInput').value; save(); });
    $('#phoneInput').addEventListener('input', save);
    $('#codeInput').addEventListener('input', save);

    function bootstrap(){
      if(!location.hash) location.hash = '#login';
      render();
      renderTime();
      setInterval(renderTime, 1000);
    }

    window.addEventListener('hashchange', render);
    window.addEventListener('load', bootstrap);
  </script>
</body>
</html>
